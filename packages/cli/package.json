{
  "name": "@jarvis/cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "jarvis": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "test": "vitest run",
    "dev": "tsc -p tsconfig.lib.json --watch"
  },
  "dependencies": {
    "@jarvis/agent": "workspace:*",
    "@jarvis/core": "workspace:*",
    "@jarvis/storage": "workspace:*",
    "@jarvis/tools-jira": "workspace:*",
    "@jarvis/tools-refine": "workspace:*",
    "@jarvis/tools-code": "workspace:*",
    "@jarvis/tools-n8n": "workspace:*",
    "commander": "^13.1.0",
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.4.1",
    "ora": "^8.2.0",
    "marked": "^15.0.0",
    "marked-terminal": "^7.3.0"
  }
}
